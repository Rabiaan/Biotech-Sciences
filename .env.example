# ── Supabase (required) ──────────────────────────────────────────────────────
# Project URL (public) — also derivable from SQL_HOST if omitted
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon key (public, safe for browser) — from Supabase Dashboard → Settings → API
SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key (server only — NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Admin seed credentials (server-only, used by scripts/createAdmin.js)
ADMIN_SEED_EMAIL=admin@biotechsciences.com
ADMIN_SEED_PASSWORD=change_me

# ── PostgreSQL direct connection (Supabase) ──────────────────────────────────
# On Windows, direct db.*.supabase.co may fail (IPv6). Use Session pooler instead:
# Settings → Database → Connection string → Session pooler
SQL_HOST=aws-0-REGION.pooler.supabase.com
SQL_PORT=5432
SQL_USER=postgres.YOUR_PROJECT_REF
SQL_PASSWORD=your_database_password
SQL_DB_NAME=postgres

# Optional: single connection string instead of SQL_* vars
# DATABASE_URL=postgresql://postgres:password@db.ref.supabase.co:5432/postgres

# ── App config ───────────────────────────────────────────────────────────────
PORT=3000
APP_URL=http://localhost:3000
ADMIN_EMAILS=admin@biotechsciences.com
LOW_STOCK_THRESHOLD=15

# ── Optional ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
